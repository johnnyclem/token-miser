{
  "name": "token-miser",
  "version": "0.1.0",
  "description": "Claude Code token usage analyzer — cost breakdowns, optimization suggestions, and A/B harness testing",
  "type": "module",
  "bin": {
    "token-miser": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:dashboard && npm run build:marketing",
    "build:cli": "tsc",
    "build:dashboard": "vite build --config dashboard/vite.config.ts",
    "build:marketing": "vite build --config marketing/vite.config.ts",
    "dev:dashboard": "vite --config dashboard/vite.config.ts",
    "dev:marketing": "vite --config marketing/vite.config.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "token",
    "usage",
    "cost",
    "analyzer",
    "optimization"
  ],
  "license": "MIT",
  "author": "token-miser contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/johnnyclem/token-miser"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
